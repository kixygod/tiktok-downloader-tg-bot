    "fastify": "^4.25.2",
    "@fastify/basic-auth": "^4.0.0",
    "bullmq": "^4.15.4",
    "ioredis": "^5.3.2",
    "pg": "^8.13.0",
    "https-proxy-agent": "^7.0.2",
    "undici": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.3.2",
    "tsx": "^4.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
