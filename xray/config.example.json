{
  "log": {
    "level": "warn"
  },
  "inbounds": [
    {
      "type": "socks",
      "tag": "socks-in",
      "listen": "0.0.0.0",
      "listen_port": 1080,
      "sniff": true,
      "sniff_override_destination": false
    },
    {
      "type": "http",
      "tag": "http-in",
      "listen": "0.0.0.0",
      "listen_port": 1087,
      "sniff": true,
      "sniff_override_destination": false
    }
  ],
  "outbounds": [
    {
      "type": "hysteria2",
      "tag": "hysteria2-out",
      "server": "YOUR_SERVER_IP",
      "server_port": 443,
      "password": "YOUR_PASSWORD",
      "tls": {
        "enabled": true,
        "server_name": "YOUR_SERVER_NAME",
        "insecure": false
      },
      "obfs": {
        "type": "salamander",
        "password": "YOUR_OBFS_PASSWORD"
      }
    },
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rules": [
      {
        "ip": [
          "geoip:cn",
          "geoip:private"
        ],
        "outbound": "direct"
      },
      {
        "domain": [
          "geosite:cn"
        ],
        "outbound": "direct"
      },
      {
        "network": "tcp,udp",
        "outbound": "hysteria2-out"
      }
    ],
    "final": "hysteria2-out"
  },
  "dns": {
    "servers": [
      {
        "tag": "google",
        "address": "tls://8.8.8.8",
        "detour": "direct"
      },
      {
        "tag": "cloudflare",
        "address": "tls://1.1.1.1",
        "detour": "direct"
      },
      {
        "tag": "local",
        "address": "local",
        "detour": "direct"
      }
    ],
    "strategy": "prefer_ipv4",
    "rules": []
  }
}

