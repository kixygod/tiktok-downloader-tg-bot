# Telegram Bot Token (получите у @BotFather)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ID вашего личного чата с ботом (для админ-команд)
# Узнать: напишите боту /start и посмотрите логи, или используйте @userinfobot
ADMIN_CHAT_ID=

# Пароль PostgreSQL (по умолчанию botpass)
POSTGRES_PASSWORD=botpass

# Базовый доступ к дашборду (логин:пароль)
DASHBOARD_BASIC_AUTH=admin:your_secure_password

# Включение/выключение использования Xray-прокси
# true  - поднимаем контейнеры xray и проксируем трафик через них
# false - НЕ поднимаем xray и работаем напрямую без прокси
USE_XRAY=true

# Настройки Hysteria2/VLESS/Shadowsocks (заполняются в xray/config*.json)
# Значения ниже используются docker-compose.yml для проксей внутри контейнеров
# По умолчанию указывают на сервисы xray во внутренней docker-сети
XRAY_HTTP_PROXY=http://xray:1087
XRAY_HTTPS_PROXY=http://xray:1087
XRAY_ALL_PROXY=socks5h://xray:1080

YTDLP_PROXY_HYSTERIA2=http://xray:1087
YTDLP_PROXY_VLESS=http://xray-vless:1087
YTDLP_PROXY_SHADOWSOCKS=http://xray-shadowsocks:1087

# FFmpeg preset при сжатии (veryfast/ultrafast — быстрее, но хуже качество)
FFMPEG_PRESET=veryfast

# Rate limit: запросов в минуту на пользователя (0 = без лимита, админы не ограничены)
RATE_LIMIT_PER_MINUTE=10

# Интервал очистки кэша видео (минуты, по умолчанию 60)
CACHE_CLEANUP_INTERVAL_MINUTES=60

# Параллельная загрузка изображений (фото-посты TikTok)
IMAGE_DOWNLOAD_CONCURRENCY=8

# --- Экономия места на VPS ---
# TTL ключей Redis в боте (чаты TG, аватары), секунды. По умолчанию 1800 = 30 мин
REDIS_KEY_TTL_SEC=1800
# TTL кэша expand TikTok URL в воркере (сек)
REDIS_EXPAND_URL_TTL_SEC=1800
# Удалять из PostgreSQL записи jobs старше N дней (полное DELETE)
JOBS_RETENTION_DAYS=10
# Как часто запускать очистку jobs (часы)
JOBS_PURGE_INTERVAL_HOURS=6
