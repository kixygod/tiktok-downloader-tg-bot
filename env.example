# Telegram Bot Token (получите у @BotFather)
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Базовый доступ к дашборду (логин:пароль)
DASHBOARD_BASIC_AUTH=admin:your_secure_password

# Включение/выключение использования Xray-прокси
# true  - поднимаем контейнеры xray и проксируем трафик через них
# false - НЕ поднимаем xray и работаем напрямую без прокси
USE_XRAY=true

# Настройки Hysteria2/VLESS/Shadowsocks (заполняются в xray/config*.json)
# Значения ниже используются docker-compose.yml для проксей внутри контейнеров
# По умолчанию указывают на сервисы xray во внутренней docker-сети
XRAY_HTTP_PROXY=http://xray:1087
XRAY_HTTPS_PROXY=http://xray:1087
XRAY_ALL_PROXY=socks5h://xray:1080

YTDLP_PROXY_HYSTERIA2=http://xray:1087
YTDLP_PROXY_VLESS=http://xray-vless:1087
YTDLP_PROXY_SHADOWSOCKS=http://xray-shadowsocks:1087
